# Mintry Fabric — Environment Variables
#
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# Duplicate this file as .env and fill in your values

# ── Control Plane (Supabase) ──────────────────────────────────────────────────
# Required for policy synchronization and telemetry uploads
MINTRY_CONTROL_PLANE_URL="https://your-project.supabase.co"
MINTRY_CONTROL_PLANE_KEY="your-anon-key"
MINTRY_SERVICE_ROLE_KEY="your-service-role-key"

# ── Policy Verification (ES256) ───────────────────────────────────────────────
# Generated by setup-supabase-integration.py
MINTRY_POLICY_PUBLIC_KEY="MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE..."
MINTRY_POLICY_PRIVATE_KEY="MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg..."

# ── Local Development ─────────────────────────────────────────────────────────
# Hide noisy test events in the dashboard
MINTRY_DEMO_MODE=1
# Uniquely identifies this instance/agent in the control plane
MINTRY_AGENT_ID="default_agent"
